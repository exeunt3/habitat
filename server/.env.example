# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://habitat:habitat@localhost:5432/habitat"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"

# ── Admin ──────────────────────────────────────────────────────────────────────
# Required to use the /setup page and POST /api/admin/deployments.
# Set a strong secret and keep it out of version control.
ADMIN_KEY="change-me"

# ── SMTP (magic-link emails) ───────────────────────────────────────────────────
# Any SMTP-compatible provider works (SendGrid, Postmark, Mailgun, Gmail, etc.)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"           # true for port 465
SMTP_USER="your@email.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Habitat <no-reply@yourcompany.com>"

# ── Server ────────────────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="production"
